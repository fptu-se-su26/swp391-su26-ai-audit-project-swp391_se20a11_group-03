# Copy this file to application.properties and provide the required environment variables.
# Do not commit application.properties or any real credentials.

# Application
spring.application.name=auction-backend
server.port=${PORT:8096}

# Database - Supabase PostgreSQL
# Get the connection details from: Supabase Dashboard > Project Settings > Database > Connection string
spring.datasource.url=${SUPABASE_DB_URL}
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.username=${SUPABASE_DB_USER}
spring.datasource.password=${SUPABASE_DB_PASSWORD}

# Database connection pool (HikariCP)
spring.datasource.hikari.maximum-pool-size=${DB_POOL_MAX_SIZE:5}
spring.datasource.hikari.minimum-idle=${DB_POOL_MIN_IDLE:1}
spring.datasource.hikari.connection-timeout=${DB_CONNECTION_TIMEOUT_MS:30000}
spring.datasource.hikari.idle-timeout=${DB_IDLE_TIMEOUT_MS:600000}
spring.datasource.hikari.max-lifetime=${DB_MAX_LIFETIME_MS:1800000}

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=${JPA_SHOW_SQL:false}
spring.jpa.open-in-view=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl

# JWT
app.jwt.secret=${APP_JWT_SECRET}
app.jwt.expiration-ms=86400000

# CORS
app.cors.allowed-origins=${APP_CORS_ALLOWED_ORIGINS:http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001}
app.cors.allowed-origin-patterns=${APP_CORS_ALLOWED_ORIGIN_PATTERNS:}

# Google OAuth
app.google.client-id=${GOOGLE_CLIENT_ID:}

# Frontend links used in verification emails
app.frontend.base-url=${APP_FRONTEND_BASE_URL:http://localhost:3000}

# SMTP email verification
vnec.mail.smtp.auth=${MAIL_SMTP_AUTH:true}
vnec.mail.smtp.starttls=${MAIL_SMTP_STARTTLS:true}
vnec.mail.smtp.host=${MAIL_SMTP_HOST:smtp.gmail.com}
vnec.mail.smtp.port=${MAIL_SMTP_PORT:587}
vnec.mail.username=${MAIL_USERNAME:}
vnec.mail.password=${MAIL_PASSWORD:}
vnec.mail.from=${MAIL_FROM:${MAIL_USERNAME:}}

# Twilio Verify phone OTP (SMS / WhatsApp)
twilio.verify.api-key=${TWILIO_API_KEY:${TWILIO_ACCOUNT_SID:}}
twilio.verify.api-secret=${TWILIO_API_SECRET:${TWILIO_AUTH_TOKEN:}}
twilio.verify.service-sid=${TWILIO_VERIFY_SERVICE_SID:}

# SpeedSMS fallback for Vietnamese SMS
speedsms.access-token=${SPEEDSMS_ACCESS_TOKEN:}
speedsms.sms-type=${SPEEDSMS_SMS_TYPE:2}
speedsms.sender=${SPEEDSMS_SENDER:}

# File upload
app.upload.dir=${APP_UPLOAD_DIR:${user.dir}/uploads}
app.kyc.upload-dir=${APP_KYC_UPLOAD_DIR:${user.dir}/uploads/kyc}
app.kyc.public-prefix=/uploads/kyc
spring.servlet.multipart.max-file-size=20MB
spring.servlet.multipart.max-request-size=100MB

# Cloudinary (image storage)
# Get these from: Cloudinary Console > Settings > API Keys
cloudinary.cloud-name=${CLOUDINARY_CLOUD_NAME:}
cloudinary.api-key=${CLOUDINARY_API_KEY:}
cloudinary.api-secret=${CLOUDINARY_API_SECRET:}
cloudinary.folder.products=${CLOUDINARY_FOLDER_PRODUCTS:auction/products}
cloudinary.folder.kyc=${CLOUDINARY_FOLDER_KYC:auction/kyc}

# Groq
# Set GROQ_API_KEY in the environment. Never put a real key in this file.
groq.api.key=${GROQ_API_KEY:}
groq.api.keys=${GROQ_API_KEYS:}
groq.ocr.api.key=${GROQ_OCR_API_KEY:${groq.api.key:}}
groq.valuation.api.key=${GROQ_VALUATION_API_KEY:${groq.api.key:}}
groq.chat.api.key=${GROQ_CHAT_API_KEY:${groq.api.key:}}

# Optional task-specific pools. They fall back to GROQ_API_KEYS.
groq.ocr.api.keys=${GROQ_OCR_API_KEYS:${groq.api.keys}}
groq.valuation.api.keys=${GROQ_VALUATION_API_KEYS:${groq.api.keys}}
groq.chat.api.keys=${GROQ_CHAT_API_KEYS:${groq.api.keys}}
groq.api.base-url=${GROQ_API_BASE_URL:https://api.groq.com/openai/v1}
groq.api.model=${GROQ_API_MODEL:qwen/qwen3.6-27b}
groq.vision.model=${GROQ_VISION_MODEL:${groq.api.model}}

# SePay
sepay.bank-id=${SEPAY_BANK_ID:}
sepay.bank-account=${SEPAY_BANK_ACCOUNT:}
sepay.account-name=${SEPAY_ACCOUNT_NAME:}
sepay.webhook-api-key=${SEPAY_WEBHOOK_API_KEY:}
