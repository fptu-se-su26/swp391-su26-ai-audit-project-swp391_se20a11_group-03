{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Stop Existing",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/stop-backend.ps1",
        "-Port",
        "8096"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Backend: Compile",
      "type": "shell",
      "command": ".\\mvnw.cmd",
      "args": ["-DskipTests", "compile"],
      "options": {
        "cwd": "${workspaceFolder}/src/backend",
        "env": {
          "JAVA_HOME": "C:\\Program Files\\Java\\jdk-17",
          "APP_TIME_ZONE": "Asia/Ho_Chi_Minh"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Backend: Prepare Debug",
      "dependsOn": ["Backend: Stop Existing", "Backend: Compile"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Backend: Run",
      "type": "shell",
      "command": ".\\mvnw.cmd",
      "args": ["spring-boot:run"],
      "options": {
        "cwd": "${workspaceFolder}/src/backend",
        "env": {
          "JAVA_HOME": "C:\\Program Files\\Java\\jdk-17",
          "APP_TIME_ZONE": "Asia/Ho_Chi_Minh"
        }
      },
      "dependsOn": "Backend: Prepare Debug",
      "isBackground": true,
      "problemMatcher": {
        "owner": "java",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting AuctionApplication.*",
          "endsPattern": ".*Started AuctionApplication.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Frontend: Run",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/src/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Next.js.*",
          "endsPattern": ".*Ready in.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Dev: Backend + Frontend",
      "dependsOn": ["Backend: Run", "Frontend: Run"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
