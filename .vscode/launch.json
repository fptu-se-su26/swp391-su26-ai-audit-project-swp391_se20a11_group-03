{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Backend: Debug Spring Boot",
      "request": "launch",
      "cwd": "${workspaceFolder}/src/backend",
      "mainClass": "com.auction.AuctionApplication",
      "preLaunchTask": "Backend: Prepare Debug",
      "shortenCommandLine": "argfile",
      "vmArgs": "-Dfile.encoding=UTF-8",
      "args": "",
      "env": {
        "APP_TIME_ZONE": "Asia/Ho_Chi_Minh"
      }
    },
    {
      "type": "java",
      "name": "Spring Boot-AuctionApplication<vnec-auth>",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "mainClass": "com.auction.AuctionApplication",
      "projectName": "vnec-auth",
      "args": "",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
