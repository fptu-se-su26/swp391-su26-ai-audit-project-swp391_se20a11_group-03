# Copy to backend.env and replace every CHANGE_ME value.
# Never commit backend.env.

SUPABASE_DB_URL=CHANGE_ME
SUPABASE_DB_USER=CHANGE_ME
SUPABASE_DB_PASSWORD=CHANGE_ME
APP_JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS

# Replace the sample domain after Vercel has assigned the production domain.
APP_CORS_ALLOWED_ORIGINS=https://example.vn,https://www.example.vn
APP_CORS_ALLOWED_ORIGIN_PATTERNS=
APP_FRONTEND_BASE_URL=https://example.vn
APP_FRAUD_DEVICE_HASH_SALT=CHANGE_ME_RANDOM_VALUE

GOOGLE_CLIENT_ID=CHANGE_ME

MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
